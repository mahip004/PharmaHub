PORT=5000
# Use in-memory store (no MongoDB) - leave MONGO_URI unset or set USE_MEMORY_STORE=true
USE_MEMORY_STORE=true
# MONGO_URI=mongodb://localhost:27017/hackbyte
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=7d
FASTAPI_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
# Mock payment (no real Stripe) - leave unset or set to mock
STRIPE_SECRET_KEY=mock
